PORT=5001
NODE_ENV=development

# MongoDB — local or Atlas
MONGODB_URI=mongodb://localhost:27017/mydiary

# Auth — generate with: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
DIARY_PASSWORD_HASH=$2a$12$NMBsBQfaOykvcu7.7cfcceSgB.i5zNn6SfJDQTgdZq/OKnJ/5e4GK

# JWT — use a long random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=$2a$12$NMBsBQfaOykvcu7.7cfcceSgB.i5zNn6SfJDQTgdZq/OKnJ/5e4GK
JWT_EXPIRES_IN=30d
